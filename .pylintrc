[MASTER]
disable=
    too-many-arguments,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    line-too-long,
    fixme,
    import-outside-toplevel,
    broad-except,
    duplicate-code,

[FORMAT]
max-line-length=120

[DESIGN]
max-attributes=10
max-arguments=8
